<?xml version="1.0" encoding="utf-8"?>
<!--
  Background for AlertDialogs themed with GbDialogTheme. Matches the
  rounded "glass card" look used elsewhere in the app — dark surface,
  subtle white stroke, generous corner radius.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/gb_surface" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="#22FFFFFF" />
</shape>
