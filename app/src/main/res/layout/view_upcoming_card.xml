<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/upcoming_card_root"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:focusable="false">

    <!-- Glass container drawn by code -->
    <FrameLayout
        android:id="@+id/upcoming_glass_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Thumbnail area (same as video card) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/card_thumb_height">

                <ImageView
                    android:id="@+id/upcoming_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Scrim so countdown is readable over art -->
                <View
                    android:id="@+id/upcoming_scrim"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Bottom gradient for text readability -->
                <View
                    android:id="@+id/upcoming_gradient"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="bottom" />

                <!-- Countdown centered on the image -->
                <LinearLayout
                    android:id="@+id/upcoming_countdown_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Days (hidden when 0) -->
                    <LinearLayout
                        android:id="@+id/upcoming_days_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/upcoming_days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DAY"
                            android:textColor="#80FFFFFF"
                            android:textSize="8sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/upcoming_sep1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#80FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone" />

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/upcoming_hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HR"
                            android:textColor="#80FFFFFF"
                            android:textSize="8sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#80FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="10dp" />

                    <!-- Minutes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/upcoming_minutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MIN"
                            android:textColor="#80FFFFFF"
                            android:textSize="8sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#80FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="10dp" />

                    <!-- Seconds -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/upcoming_seconds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SEC"
                            android:textColor="#80FFFFFF"
                            android:textSize="8sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </LinearLayout>

                <!-- LIVE NOW badge -->
                <TextView
                    android:id="@+id/upcoming_live_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="LIVE NOW"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:visibility="gone" />

                <!-- Premium badge -->
                <TextView
                    android:id="@+id/upcoming_premium_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="PREMIUM"
                    android:textColor="#1A1A1A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Text area with glass tint (matches video card) -->
            <LinearLayout
                android:id="@+id/upcoming_text_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/upcoming_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gb_text_primary"
                    android:textSize="14sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/upcoming_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gb_text_tertiary"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
