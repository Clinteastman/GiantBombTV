<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/card_root"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:focusable="false">

    <!-- Glass container drawn by code (semi-transparent bg + border) -->
    <FrameLayout
        android:id="@+id/card_glass_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Thumbnail area -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/card_thumb_height">

                <ImageView
                    android:id="@+id/card_thumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Bottom gradient for text readability -->
                <View
                    android:id="@+id/card_gradient"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="bottom" />

                <!-- Progress bar (track hidden by default, shown via code) -->
                <FrameLayout
                    android:id="@+id/card_progress_track"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_gravity="bottom"
                    android:background="@color/gb_progress_track"
                    android:visibility="gone">

                    <View
                        android:id="@+id/card_progress"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@color/gb_progress_bar" />
                </FrameLayout>

                <!-- Premium badge -->
                <TextView
                    android:id="@+id/card_premium_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="PREMIUM"
                    android:textColor="#1A1A1A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:visibility="gone" />

                <!-- Watched checkmark badge -->
                <TextView
                    android:id="@+id/card_watched_badge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="\u2713"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Text area with glass tint -->
            <LinearLayout
                android:id="@+id/card_text_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/card_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gb_text_primary"
                    android:textSize="14sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/card_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gb_text_tertiary"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
