<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp">

    <FrameLayout
        android:id="@+id/upcoming_card_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image + countdown overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="130dp">

                <ImageView
                    android:id="@+id/upcoming_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- Scrim -->
                <View
                    android:id="@+id/upcoming_scrim"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Countdown centered on image -->
                <LinearLayout
                    android:id="@+id/upcoming_countdown_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Days -->
                    <LinearLayout
                        android:id="@+id/upcoming_days_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/upcoming_days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DAY"
                            android:textColor="#80FFFFFF"
                            android:textSize="7sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/upcoming_sep1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#80FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone" />

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/upcoming_hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HR"
                            android:textColor="#80FFFFFF"
                            android:textSize="7sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#80FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="10dp" />

                    <!-- Minutes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/upcoming_minutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MIN"
                            android:textColor="#80FFFFFF"
                            android:textSize="7sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="#80FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="10dp" />

                    <!-- Seconds -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/upcoming_seconds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SEC"
                            android:textColor="#80FFFFFF"
                            android:textSize="7sp"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </LinearLayout>

                <!-- LIVE badge -->
                <TextView
                    android:id="@+id/upcoming_live_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="LIVE NOW"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:visibility="gone" />

                <!-- Premium badge -->
                <TextView
                    android:id="@+id/upcoming_premium_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="PREMIUM"
                    android:textColor="#1A1A1A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Text area -->
            <LinearLayout
                android:id="@+id/upcoming_text_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/upcoming_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gb_text_primary"
                    android:textSize="13sp"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/upcoming_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gb_text_tertiary"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="3dp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
