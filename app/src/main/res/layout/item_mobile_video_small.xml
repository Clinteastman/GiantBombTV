<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:paddingBottom="4dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Thumbnail with 16:9 ratio -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/small_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="83dp"
            android:scaleType="centerCrop" />

        <!-- Progress bar -->
        <View
            android:id="@+id/small_progress_track"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="bottom"
            android:visibility="gone" />

        <View
            android:id="@+id/small_progress_bar"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_gravity="bottom|start"
            android:background="@color/gb_red"
            android:visibility="gone" />

        <!-- Watched checkmark -->
        <TextView
            android:id="@+id/small_watched"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:gravity="center"
            android:text="\u2713"
            android:textColor="@color/gb_white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/small_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/gb_white"
        android:textSize="14sp"
        tools:text="Video Title" />

    <TextView
        android:id="@+id/small_show_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/gb_text_secondary"
        android:textSize="12sp"
        tools:text="Show Name" />

</LinearLayout>
