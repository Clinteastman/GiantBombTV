<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Bridge parent: inherits AppCompat behaviour (so the existing Leanback TV
         UI and AppCompat dialogs are unchanged) while supplying the Material
         theme attributes that com.google.android.material widgets such as
         BottomNavigationView require — without a Material theme they throw at
         inflation, which previously crashed every mobile launch. -->
    <style name="Theme.GiantBombTV" parent="Theme.MaterialComponents.NoActionBar.Bridge">
        <item name="android:colorPrimary">@color/gb_red</item>
        <item name="android:colorPrimaryDark">@color/gb_red_dark</item>
        <item name="android:colorAccent">@color/gb_red</item>
        <item name="android:windowBackground">@color/gb_background</item>
        <!-- Edge-to-edge handled by enableEdgeToEdge() on phones -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Dialog theme used for the side-menu header context menu (and any
         future AlertDialogs). Rounded corners + dark glass surface to match
         the rest of the app instead of the default square white box. -->
    <style name="GbDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:colorAccent">@color/gb_red</item>
        <item name="android:windowBackground">@drawable/gb_dialog_background</item>
        <item name="android:textColor">@color/gb_white</item>
        <item name="android:textColorPrimary">@color/gb_white</item>
        <item name="android:textColorSecondary">#CCFFFFFF</item>
    </style>
</resources>
