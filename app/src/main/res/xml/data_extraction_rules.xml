<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ replacement for android:allowBackup="false". Disables both
  cloud backup and device-to-device transfer for every data domain so
  the API key (stored in SharedPreferences) cannot be extracted via
  `adb backup`, Google One backup, or D2D migration.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
